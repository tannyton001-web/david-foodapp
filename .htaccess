ErrorDocument 404 /404.html

# Chặn mọi dotfile (.env, .gitignore, .htaccess, .DS_Store...) khỏi web root.
# Match theo TÊN FILE (không theo path) nên KHÔNG ảnh hưởng thư mục
# .well-known/ (vd /.well-known/security.txt có tên file "security.txt",
# không bắt đầu bằng dấu chấm).
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Thư mục làm việc không thuộc deploy chuẩn — trả 404 (không tiết lộ path có
# tồn tại hay không) phòng trường hợp file bị upload nhầm lên web root.
RedirectMatch 404 ^/(\.claude|apps-script|audit-screenshots|dist)(/|$)

# Chặn file tài liệu cục bộ đích danh (không dùng wildcard *.md — README.md
# vẫn public).
<FilesMatch "^(CLAUDE|HANDOFF.*)\.md$">
  Require all denied
</FilesMatch>

# Site tĩnh không serve archive/log/backup/dump — chặn theo extension và tên.
<FilesMatch "\.(zip|tar|gz|tgz|rar|7z|log|bak|sql)$">
  Require all denied
</FilesMatch>
<FilesMatch "^(error_log|debug\.log)$">
  Require all denied
</FilesMatch>

# HTML luôn revalidate với server (no-cache ≠ no-store: vẫn cache nhưng phải
# hỏi lại trước khi dùng) để HTML mới và asset version query (?v=) flip đồng
# bộ ngay sau deploy; css/js giữ max-age dài mặc định của host vì đã có
# version query lo việc cập nhật.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
